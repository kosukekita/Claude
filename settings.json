{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$HOME/.claude/hooks/block-dangerous.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$HOME/.claude/hooks/log-commands.ps1\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$HOME/.claude/hooks/protect-files.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$HOME/.claude/hooks/auto-pull.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$HOME/.claude/hooks/auto-push.ps1\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "model": "opusplan",
  "autoUpdatesChannel": "latest",
  "effortLevel": "high",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "WebFetch",
      "Edit",
      "Bash",
      "Write"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}